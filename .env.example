# ============================================================
#  InterviewIntel — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to git.
# ============================================================

# ── Claude API ───────────────────────────────────────────────
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your-key-here

# ── Reddit API ───────────────────────────────────────────────
# Get from: https://www.reddit.com/prefs/apps
# Create a "script" type app. Use any redirect URI e.g. http://localhost
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# ── Database (used by Spring Boot backend) ───────────────────
# If using Docker Compose, these are pre-filled — no change needed
DB_USER=postgres
DB_PASSWORD=password

# ── Redis (used by Spring Boot backend) ──────────────────────
# If using Docker Compose, these are pre-filled — no change needed
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Frontend ──────────────────────────────────────────────────
# Points to your Spring Boot backend
# Local dev: http://localhost:8080
# Production: https://your-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080
